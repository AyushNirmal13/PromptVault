{
  "manifest_version": 3,
  "name": "PromptVault",
  "version": "1.0.0",
  "description": "Access and inject your PromptVault prompts into ChatGPT, Gemini, and Claude instantly.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PromptVault"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://www.bing.com/chat*",
        "https://bard.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.render.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel/panel.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
